services:
  watchtower:
    image: containrrr/watchtower:{{ vars.version | default('latest') }}
    container_name: watchtower
    restart: unless-stopped
    environment:
      - TZ={{ global.timezone }}
      - WATCHTOWER_SCHEDULE={{ vars.schedule | default('0 0 4 * * *') }}
      - WATCHTOWER_CLEANUP={{ vars.cleanup | default(true) | lower }}
      - WATCHTOWER_INCLUDE_RESTARTING=true
{% if security.socket_proxy %}
      - DOCKER_HOST=tcp://socket-proxy:2375
{% endif %}
{% if not security.socket_proxy %}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
{% endif %}
    networks:
{% if security.socket_proxy %}
      - socket_proxy
{% else %}
      - proxy
{% endif %}

networks:
{% if security.socket_proxy %}
  socket_proxy:
    external: true
{% else %}
  proxy:
    external: true
{% endif %}
