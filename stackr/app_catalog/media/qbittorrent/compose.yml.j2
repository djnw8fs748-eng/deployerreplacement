services:
  qbittorrent:
    image: lscr.io/linuxserver/qbittorrent:{{ vars.version | default('latest') }}
    container_name: qbittorrent
    restart: unless-stopped
{% if vars.use_vpn | default(false) %}
    network_mode: "service:gluetun"
{% endif %}
    environment:
      - PUID={{ global.puid }}
      - PGID={{ global.pgid }}
      - TZ={{ global.timezone }}
      - WEBUI_PORT={{ vars.webui_port | default(8080) }}
    volumes:
      - {{ global.data_dir }}/qbittorrent/config:/config
      - /downloads:/downloads
{% if not vars.use_vpn | default(false) %}
    ports:
      - "6881:6881/tcp"
      - "6881:6881/udp"
    networks:
      - proxy
    labels:
{% for k, v in traefik_labels(vars.webui_port | default(8080)).items() %}
      - "{{ k }}={{ v }}"
{% endfor %}
{% endif %}

{% if not vars.use_vpn | default(false) %}
networks:
  proxy:
    external: true
{% endif %}
