services:
  authelia-redis:
    image: redis:alpine
    container_name: authelia-redis
    restart: unless-stopped
    command: --save 60 1 --loglevel warning
    volumes:
      - {{ global.data_dir }}/authelia/redis:/data
    healthcheck:
      test: ["CMD-SHELL", "redis-cli ping | grep PONG"]
      interval: 30s
      timeout: 3s
      retries: 5
    networks:
      - authelia-internal

  authelia:
    image: authelia/authelia:{{ vars.version | default('latest') }}
    container_name: authelia
    restart: unless-stopped
    environment:
      - TZ={{ global.timezone }}
      - AUTHELIA_JWT_SECRET=${AUTHELIA_JWT_SECRET}
      - AUTHELIA_SESSION_SECRET=${AUTHELIA_SESSION_SECRET}
      - AUTHELIA_STORAGE_ENCRYPTION_KEY=${AUTHELIA_STORAGE_ENCRYPTION_KEY}
      - AUTHELIA_SESSION_REDIS_HOST=authelia-redis
    volumes:
      - {{ global.data_dir }}/authelia/config:/config
    depends_on:
      authelia-redis:
        condition: service_healthy
    networks:
      - proxy
      - authelia-internal
    labels:
{% for k, v in traefik_labels(9091).items() %}
      - "{{ k }}={{ v }}"
{% endfor %}
      - "traefik.http.middlewares.authelia.forwardauth.address=http://authelia:9091/api/verify?rd=https://auth.{{ network.domain }}/"
      - "traefik.http.middlewares.authelia.forwardauth.trustForwardHeader=true"
      - "traefik.http.middlewares.authelia.forwardauth.authResponseHeaders=Remote-User,Remote-Groups,Remote-Name,Remote-Email"

networks:
  proxy:
    external: true
  authelia-internal:
    driver: bridge
