services:
  filebrowser:
    image: filebrowser/filebrowser:{{ vars.version | default('latest') }}
    container_name: filebrowser
    restart: unless-stopped
    environment:
      - TZ={{ global.timezone }}
    volumes:
      - {{ global.data_dir }}/filebrowser/config:/config
      - {{ global.data_dir }}:/srv
    networks:
      - proxy

networks:
  proxy:
    external: true
