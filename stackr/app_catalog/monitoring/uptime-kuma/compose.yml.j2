services:
  uptime-kuma:
    image: louislam/uptime-kuma:{{ vars.version | default('latest') }}
    container_name: uptime-kuma
    restart: unless-stopped
    environment:
      - TZ={{ global.timezone }}
    volumes:
      - {{ global.data_dir }}/uptime-kuma/data:/app/data
    networks:
      - proxy

networks:
  proxy:
    external: true
