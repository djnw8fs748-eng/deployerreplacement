services:
  paperless-ngx:
    image: ghcr.io/paperless-ngx/paperless-ngx:{{ vars.version | default('latest') }}
    container_name: paperless-ngx
    restart: unless-stopped
    depends_on:
      - paperless-db
      - paperless-redis
      - paperless-gotenberg
      - paperless-tika
    environment:
      - TZ={{ global.timezone }}
      - PAPERLESS_REDIS=redis://paperless-redis:6379
      - PAPERLESS_DBHOST=paperless-db
      - PAPERLESS_DBNAME=paperless
      - PAPERLESS_DBUSER=paperless
      - PAPERLESS_DBPASS=${PAPERLESS_DB_PASSWORD}
      - PAPERLESS_TIKA_ENABLED=1
      - PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://paperless-gotenberg:3000
      - PAPERLESS_TIKA_ENDPOINT=http://paperless-tika:9998
      - PAPERLESS_SECRET_KEY=${PAPERLESS_SECRET_KEY}
      - PAPERLESS_URL=https://paperless.{{ network.domain }}
      - PAPERLESS_ADMIN_USER={{ vars.admin_user | default('admin') }}
      - PAPERLESS_ADMIN_PASSWORD=${PAPERLESS_ADMIN_PASSWORD}
    volumes:
      - {{ global.data_dir }}/paperless-ngx/data:/usr/src/paperless/data
      - {{ global.data_dir }}/paperless-ngx/media:/usr/src/paperless/media
      - {{ global.data_dir }}/paperless-ngx/consume:/usr/src/paperless/consume
      - {{ global.data_dir }}/paperless-ngx/export:/usr/src/paperless/export
    networks:
      - proxy
      - paperless-backend
    labels:
{% for k, v in traefik_labels(8000).items() %}
      - "{{ k }}={{ v }}"
{% endfor %}

  paperless-db:
    image: postgres:16-alpine
    container_name: paperless-db
    restart: unless-stopped
    environment:
      - POSTGRES_DB=paperless
      - POSTGRES_USER=paperless
      - POSTGRES_PASSWORD=${PAPERLESS_DB_PASSWORD}
    volumes:
      - {{ global.data_dir }}/paperless-ngx/db:/var/lib/postgresql/data
    networks:
      - paperless-backend
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U paperless"]
      interval: 30s
      timeout: 10s
      retries: 5

  paperless-redis:
    image: redis:7-alpine
    container_name: paperless-redis
    restart: unless-stopped
    networks:
      - paperless-backend
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 30s
      timeout: 10s
      retries: 5

  paperless-gotenberg:
    image: gotenberg/gotenberg:8
    container_name: paperless-gotenberg
    restart: unless-stopped
    command:
      - gotenberg
      - --chromium-disable-javascript=true
      - --chromium-allow-list=file:///tmp/.*
    networks:
      - paperless-backend

  paperless-tika:
    image: ghcr.io/paperless-ngx/tika:latest
    container_name: paperless-tika
    restart: unless-stopped
    networks:
      - paperless-backend

networks:
  proxy:
    external: true
  paperless-backend:
    external: false
