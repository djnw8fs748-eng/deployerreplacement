# stackr.yml — example configuration
# Copy to stackr.yml and edit to your needs.
# Run: stackr init  (for an interactive wizard that generates this automatically)
#
# Toggle apps on/off with:
#   stackr ui          — interactive TUI
#   stackr web         — browser dashboard
#   edit this file     — flip enabled: false → true

global:
  data_dir: /opt/appdata       # Where container data volumes are stored
  timezone: America/New_York
  puid: 1000
  pgid: 1000

catalog:
  source: github               # github | local
  version: latest              # Pin to a release tag (e.g. v1.2.0) or "latest"
  # local_path: ./my-catalog   # Use a local catalog directory

network:
  mode: external               # external | internal | hybrid
  domain: example.com          # Public domain
  local_domain: home.example.com  # Local-only domain (used in internal/hybrid mode)

traefik:
  enabled: true
  acme_email: you@example.com
  dns_provider: cloudflare     # cloudflare | route53 | namecheap | porkbun | duckdns | ...
  dns_provider_env:
    CF_DNS_API_TOKEN: "${CF_DNS_API_TOKEN}"  # Resolved from .stackr.env or shell env

security:
  socket_proxy: true           # Recommended: proxy Docker socket access
  crowdsec: false              # Enable CrowdSec bouncer (requires crowdsec in apps)
  auth_provider: none          # authentik | authelia | google_oauth | none

backup:
  enabled: false
  destination: /mnt/backup     # restic repository path (local or s3:bucket/path)
  schedule: "0 2 * * *"        # informational — no built-in scheduler

# Push notifications on deploy failures and doctor errors
# alerts:
#   enabled: false
#   provider: ntfy             # ntfy | gotify | webhook
#   url: https://ntfy.sh/my-homelab
#   token: "${NTFY_TOKEN}"    # optional Bearer token

# Remote share mounts — applied by: stackr mount / stackr umount
# mounts:
#   - name: media
#     type: smb                # smb | nfs | rclone
#     remote: //192.168.1.10/media
#     mountpoint: /mnt/media
#     username: myuser
#     password: "${SMB_PASSWORD}"
#   - name: photos
#     type: nfs
#     remote: 192.168.1.10:/export/photos
#     mountpoint: /mnt/photos
#     options: ro,noatime

# ---------------------------------------------------------------------------
# Apps — all catalog apps listed below, grouped by category.
# Only traefik and portainer are enabled by default.
# Flip enabled: false → true to add an app, then run: stackr deploy
# ---------------------------------------------------------------------------

apps:

  # --- ai ---
  - name: ollama
    enabled: false
  - name: open-webui
    enabled: false

  # --- dashboard ---
  - name: homepage
    enabled: false

  # --- database ---
  - name: mariadb
    enabled: false
  - name: mongo
    enabled: false
  - name: postgres
    enabled: false
  - name: redis
    enabled: false

  # --- gaming ---
  - name: minecraft
    enabled: false

  # --- management ---
  - name: dasherr
    enabled: false
  - name: dozzle
    enabled: false
  - name: flame
    enabled: false
  - name: heimdall
    enabled: false
  - name: portainer
    enabled: true
  - name: watchtower
    enabled: false

  # --- media ---
  - name: bazarr
    enabled: false
  - name: jellyfin
    enabled: false
  - name: jellyseerr
    enabled: false
  - name: lidarr
    enabled: false
  - name: overseerr
    enabled: false
  - name: plex
    enabled: false
  - name: prowlarr
    enabled: false
  - name: qbittorrent
    enabled: false
  - name: radarr
    enabled: false
  - name: readarr
    enabled: false
  - name: sabnzbd
    enabled: false
  - name: sonarr
    enabled: false
  - name: tdarr
    enabled: false
  - name: transmission
    enabled: false

  # --- monitoring ---
  - name: grafana
    enabled: false
  - name: loki
    enabled: false
  - name: netdata
    enabled: false
  - name: prometheus
    enabled: false
  - name: uptime-kuma
    enabled: false

  # --- network ---
  - name: adguardhome
    enabled: false
  - name: headscale
    enabled: false
  - name: nginx-proxy-manager
    enabled: false
  - name: pihole
    enabled: false
  - name: traefik
    enabled: true
  - name: wireguard
    enabled: false

  # --- productivity ---
  - name: freshrss
    enabled: false
  - name: gitea
    enabled: false
  - name: miniflux
    enabled: false
  - name: paperless-ngx
    enabled: false

  # --- security ---
  - name: authelia
    enabled: false
  - name: authentik
    enabled: false
  - name: crowdsec
    enabled: false
  - name: socket-proxy
    enabled: false
  - name: vaultwarden
    enabled: false

  # --- storage ---
  - name: duplicati
    enabled: false
  - name: filebrowser
    enabled: false
  - name: nextcloud
    enabled: false

  # Custom local app example:
  # - name: my-app
  #   enabled: true
  #   catalog_path: ./local-catalog/my-app
  #   overrides:
  #     services:
  #       my-app:
  #         mem_limit: 512m
