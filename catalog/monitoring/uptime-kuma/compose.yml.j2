services:
  uptime-kuma:
    image: louislam/uptime-kuma:{{ vars.version | default('latest') }}
    container_name: uptime-kuma
    restart: unless-stopped
    environment:
      - TZ={{ global.timezone }}
    volumes:
      - {{ global.data_dir }}/uptime-kuma/data:/app/data
    networks:
      - proxy
    labels:
{% for k, v in traefik_labels(3001).items() %}
      - "{{ k }}={{ v }}"
{% endfor %}

networks:
  proxy:
    external: true
