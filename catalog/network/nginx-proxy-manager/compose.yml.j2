services:
  nginx-proxy-manager:
    image: jc21/nginx-proxy-manager:{{ vars.version | default('latest') }}
    container_name: nginx-proxy-manager
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "81:81"
    environment:
      - TZ={{ global.timezone }}
    volumes:
      - {{ global.data_dir }}/nginx-proxy-manager/data:/data
      - {{ global.data_dir }}/nginx-proxy-manager/letsencrypt:/etc/letsencrypt
