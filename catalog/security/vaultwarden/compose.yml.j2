services:
  vaultwarden:
    image: vaultwarden/server:{{ vars.version | default('latest') }}
    container_name: vaultwarden
    restart: unless-stopped
    environment:
      - TZ={{ global.timezone }}
      - DOMAIN=https://vaultwarden.{{ network.domain }}
      - ADMIN_TOKEN=${VAULTWARDEN_ADMIN_TOKEN}
      - SIGNUPS_ALLOWED={{ vars.signups_allowed | default(false) | lower }}
      - INVITATIONS_ALLOWED={{ vars.invitations_allowed | default(true) | lower }}
      - SHOW_PASSWORD_HINT={{ vars.show_password_hint | default(false) | lower }}
    volumes:
      - {{ global.data_dir }}/vaultwarden/data:/data
    networks:
      - proxy

networks:
  proxy:
    external: true
