services:
  gitea:
    image: gitea/gitea:{{ vars.version | default('latest') }}
    container_name: gitea
    restart: unless-stopped
    ports:
      - "{{ vars.ssh_port | default(22) }}:22"
    environment:
      - USER_UID={{ global.puid }}
      - USER_GID={{ global.pgid }}
      - TZ={{ global.timezone }}
      - GITEA__database__DB_TYPE=sqlite3
      - GITEA__database__PATH=/data/gitea/gitea.db
      - GITEA__server__ROOT_URL=https://gitea.{{ network.domain }}
      - GITEA__server__SSH_DOMAIN=gitea.{{ network.domain }}
      - GITEA__server__SSH_PORT={{ vars.ssh_port | default(22) }}
    volumes:
      - {{ global.data_dir }}/gitea/data:/data
    networks:
      - proxy
    labels:
{% for k, v in traefik_labels(3000).items() %}
      - "{{ k }}={{ v }}"
{% endfor %}

networks:
  proxy:
    external: true
