services:
  transmission:
    image: lscr.io/linuxserver/transmission:{{ vars.version | default('latest') }}
    container_name: transmission
    restart: unless-stopped
{% if vars.use_vpn | default(false) %}
    network_mode: "service:gluetun"
{% endif %}
    environment:
      - PUID={{ global.puid }}
      - PGID={{ global.pgid }}
      - TZ={{ global.timezone }}
      - USER={{ vars.user | default('admin') }}
      - PASS=${TRANSMISSION_PASS}
    volumes:
      - {{ global.data_dir }}/transmission/config:/config
      - /downloads:/downloads
      - {{ global.data_dir }}/transmission/watch:/watch
{% if not vars.use_vpn | default(false) %}
    ports:
      - "51413:51413/tcp"
      - "51413:51413/udp"
    networks:
      - proxy
    labels:
{% for k, v in traefik_labels(9091).items() %}
      - "{{ k }}={{ v }}"
{% endfor %}
{% endif %}

{% if not vars.use_vpn | default(false) %}
networks:
  proxy:
    external: true
{% endif %}
