services:
  sabnzbd:
    image: lscr.io/linuxserver/sabnzbd:{{ vars.version | default('latest') }}
    container_name: sabnzbd
    restart: unless-stopped
    environment:
      - PUID={{ global.puid }}
      - PGID={{ global.pgid }}
      - TZ={{ global.timezone }}
    volumes:
      - {{ global.data_dir }}/sabnzbd/config:/config
      - /downloads:/downloads
      - /incomplete-downloads:/incomplete-downloads
    networks:
      - proxy
    labels:
{% for k, v in traefik_labels(8080).items() %}
      - "{{ k }}={{ v }}"
{% endfor %}

networks:
  proxy:
    external: true
