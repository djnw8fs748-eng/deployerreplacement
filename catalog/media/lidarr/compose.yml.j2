services:
  lidarr:
    image: lscr.io/linuxserver/lidarr:{{ vars.version | default('latest') }}
    container_name: lidarr
    restart: unless-stopped
    environment:
      - PUID={{ global.puid }}
      - PGID={{ global.pgid }}
      - TZ={{ global.timezone }}
    volumes:
      - {{ global.data_dir }}/lidarr/config:/config
      - /music:/music
      - /downloads:/downloads
    networks:
      - proxy

networks:
  proxy:
    external: true
