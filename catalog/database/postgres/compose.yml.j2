services:
  postgres:
    image: postgres:{{ vars.version | default('16') }}-alpine
    container_name: postgres
    restart: unless-stopped
    environment:
      - POSTGRES_USER={{ vars.postgres_user | default('postgres') }}
      - POSTGRES_DB={{ vars.postgres_db | default('postgres') }}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      - TZ={{ global.timezone }}
    volumes:
      - {{ global.data_dir }}/postgres/data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ vars.postgres_user | default('postgres') }}"]
      interval: 30s
      timeout: 10s
      retries: 5
    networks:
      - proxy

networks:
  proxy:
    external: true
