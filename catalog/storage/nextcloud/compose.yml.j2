services:
  nextcloud:
    image: nextcloud:{{ vars.version | default('29') }}-apache
    container_name: nextcloud
    restart: unless-stopped
    depends_on:
      nextcloud-db:
        condition: service_healthy
      nextcloud-redis:
        condition: service_healthy
    environment:
      - TZ={{ global.timezone }}
      - MYSQL_HOST=nextcloud-db
      - MYSQL_DATABASE=nextcloud
      - MYSQL_USER=nextcloud
      - MYSQL_PASSWORD=${NEXTCLOUD_DB_PASSWORD}
      - REDIS_HOST=nextcloud-redis
      - NEXTCLOUD_ADMIN_USER={{ vars.admin_user | default('admin') }}
      - NEXTCLOUD_ADMIN_PASSWORD=${NEXTCLOUD_ADMIN_PASSWORD}
      - NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.{{ network.domain }}
      - TRUSTED_PROXIES=172.16.0.0/12
      - OVERWRITEPROTOCOL=https
    volumes:
      - {{ global.data_dir }}/nextcloud/html:/var/www/html
      - {{ global.data_dir }}/nextcloud/data:/var/www/html/data
    networks:
      - proxy
      - nextcloud-backend
    labels:
{% for k, v in traefik_labels(80).items() %}
      - "{{ k }}={{ v }}"
{% endfor %}

  nextcloud-db:
    image: mariadb:11
    container_name: nextcloud-db
    restart: unless-stopped
    environment:
      - MYSQL_ROOT_PASSWORD=${NEXTCLOUD_DB_ROOT_PASSWORD}
      - MYSQL_DATABASE=nextcloud
      - MYSQL_USER=nextcloud
      - MYSQL_PASSWORD=${NEXTCLOUD_DB_PASSWORD}
    volumes:
      - {{ global.data_dir }}/nextcloud/db:/var/lib/mysql
    networks:
      - nextcloud-backend
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_buffer_pool_size=0"]
      interval: 30s
      timeout: 10s
      retries: 5

  nextcloud-redis:
    image: redis:7-alpine
    container_name: nextcloud-redis
    restart: unless-stopped
    networks:
      - nextcloud-backend
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 30s
      timeout: 10s
      retries: 5

networks:
  proxy:
    external: true
  nextcloud-backend:
    external: false
